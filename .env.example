# Copy this file to `.env` (it's gitignored) and fill in your keys, then run
# `npm run playground`. Or export these as environment variables instead.

# --- Score playground -------------------------------------------------------
# Your SECRET Kaidn API key. Dashboard → API keys → create (shown once).
# Server-side only — never ship this to a browser.
KAIDN_API_KEY=kaidn_live_xxxxxxxxxxxxxxxx

# --- Fingerprint test (beacon) ----------------------------------------------
# Your PUBLISHABLE tracker key. Dashboard → Device trackers → create, and add
# `localhost` as an approved domain so the local beacon test is allowed.
# Safe in browser code (beacon-only, domain-locked).
KAIDN_TRACKER_PK=pk_live_xxxxxxxxxxxxxxxx

# --- Optional ---------------------------------------------------------------
# Point at a different Kaidn environment (defaults to https://api.kaidn.io).
# KAIDN_BASE_URL=https://api.kaidn.io
