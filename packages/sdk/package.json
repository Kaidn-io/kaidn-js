{
  "name": "@kaidn/sdk",
  "version": "0.2.0",
  "description": "Official Node/TypeScript server-side client for the Kaidn fraud-scoring API — score, checks, batch, lists, labels, analytics and config.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaidn-io/kaidn-js.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Kaidn-io/kaidn-js/tree/main/packages/sdk#readme",
  "bugs": "https://github.com/Kaidn-io/kaidn-js/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "kaidn",
    "fraud",
    "fraud-detection",
    "fraud-scoring",
    "abuse",
    "risk",
    "api-client",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:lib": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^3.2.6"
  }
}
