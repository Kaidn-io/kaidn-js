{
  "name": "kaidn-js",
  "version": "0.0.0",
  "private": true,
  "description": "Official JavaScript/TypeScript client libraries for Kaidn — the AI fraud-scoring API.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaidn-io/kaidn-js.git"
  },
  "homepage": "https://kaidn.io",
  "bugs": "https://github.com/Kaidn-io/kaidn-js/issues",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p tsconfig.json --noEmit",
    "build": "npm run build:lib --workspaces --if-present",
    "playground": "npm run build:lib --workspace @kaidn/sdk && node playground/server.mjs",
    "example:score": "npm run build:lib --workspace @kaidn/sdk --silent && node --env-file-if-exists=.env packages/sdk/examples/score-signup.mjs",
    "example:batch": "npm run build:lib --workspace @kaidn/sdk --silent && node --env-file-if-exists=.env packages/sdk/examples/batch-and-lists.mjs"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.5",
    "vitest": "^3.2.6"
  }
}
